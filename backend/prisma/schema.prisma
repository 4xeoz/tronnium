// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

//
// Enums
// 

enum AssetDomain {
  IT
  OT
  UNKNOWN
}

//
// Core Auth / User
// You’re using Google OAuth + JWT in your app.
// This schema stores the user identity and basic profile info.
//

model UserAccount {
  id             String   @id @default(uuid()) @db.Uuid

  // Primary identity (unique)
  email          String   @unique

  displayName String?
  avatarUrl   String?
  role        String   @default("user")
  
  // Dev mode flag for testing features
  devMode     Boolean  @default(false)

  // Google identity: "sub" claim is stable per Google account
  googleSubjectId  String?  @unique

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Vulnerability remediation assignments
  assignedVulnerabilities VulnerabilityWorkflow[] @relation("AssignedVulnerabilities")
  resolvedVulnerabilities VulnerabilityWorkflow[] @relation("ResolvedVulnerabilities")

  @@index([createdAt])
  environments Environment[]
}



//
// Multi-tenant workspace-style structure
// User -> Environment -> Assets
// 


model Environment {
  id              String          @id @default(uuid()) @db.Uuid

  ownerId         String          @db.Uuid
  owner           UserAccount     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name            String          // e.g. "HQ IT", "Plant A OT", "Cloud Prod"
  description     String?

  // Useful for filtering (prod/dev/lab, plant-a, region-uk)
  labels          String[]        @default([])

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  assets          Asset[]
  SecurityScans    SecurityScan[]
  vulnerabilityWorkflows VulnerabilityWorkflow[]

  @@index([ownerId])
  relationships Relationship[]
}


//
// Assets
// Simple asset model - stores user input and selected CPEs with metadata
//

model Asset {
  id            String      @id @default(uuid()) @db.Uuid

  environmentId String      @db.Uuid
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  // User-entered fields
  name          String      // Asset name, e.g. "Main Firewall", "OpenSSL Server"
  description   String?     // Optional description
  
  // Asset type for visualization and categorization
  type          String      @default("unknown") // e.g., "server", "database", "network", "firewall", "iot"

  // Domain classification
  domain        AssetDomain @default(UNKNOWN)

  // Map visualization coordinates
  x             Float?      // X coordinate for map canvas positioning
  y             Float?      // Y coordinate for map canvas positioning

  // Asset metadata
  status        String?     // e.g., "active", "inactive", "maintenance", "decommissioned"
  location      String?     // Physical or logical location, e.g., "Data Center 1", "Cloud-US-East"
  ipAddress     String?     // IP address for network-connected assets
  manufacturer  String?     // Manufacturer/vendor name
  model         String?     // Model name or number
  serialNumber  String?     // Serial number or asset tag

  // CPEs selected by user with full metadata (score, breakdown, cpeNameId)
  // JSON array of: { cpeName, cpeNameId, title, score, breakdown: { vendor, product, version, tokenOverlap } }
  cpes          Json        @default("[]")

  // Optional tags for organization
  tags          String[]    @default([])

  assetScans     AssetScan[] // Vulnerability scan results for this asset
  vulnerabilityWorkflows VulnerabilityWorkflow[] // Remediation tracking

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([environmentId])
  @@index([domain])
  @@index([type])
  @@index([status])

  relationshipsFrom Relationship[] @relation("FromAsset")
  relationshipsTo   Relationship[] @relation("ToAsset")
}

model Relationship {
  id            String      @id @default(uuid()) @db.Uuid

  environmentId String      @db.Uuid
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  fromAssetId   String      @db.Uuid
  fromAsset     Asset       @relation("FromAsset", fields: [fromAssetId], references: [id], onDelete: Cascade)

  toAssetId     String      @db.Uuid
  toAsset       Asset       @relation("ToAsset", fields: [toAssetId], references: [id], onDelete: Cascade)

  type          RelationType   

  criticality   RelationshipCriticality @default(MEDIUM)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([environmentId])
  @@index([fromAssetId])
  @@index([toAssetId])
  @@index([fromAssetId, environmentId])
  @@index([toAssetId, environmentId])

  @@unique([fromAssetId, toAssetId, type])


}


enum RelationType {
  DEPENDS_ON
  CONTROLS
  PROVIDES_SERVICE
  SHARES_DATA_WITH
  
}


enum AssetType {
  SERVER
  DATABASE
  NETWORK
  FIREWALL
  IOT
  ROUTER
  SWITCH
  STORAGE
  LOAD_BALANCER
  UNKNOWN
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  DECOMMISSIONED
  UNKNOWN
}

enum RelationshipCriticality {
  LOW      // Failures won't impact service
  MEDIUM   // Degraded performance if fails
  HIGH     // Service outage if fails
  CRITICAL // System-wide outage if fails
}


enum ScanStatus   { 
  PENDING 
  IN_PROGRESS 
  COMPLETED 
  FAILED 
  
  }
enum VulnSeverity { 
  CRITICAL 
  HIGH 
  MEDIUM 
  LOW 
  NONE 
  UNKNOWN 
  }

model SecurityScan {
  id                   String      @id @default(uuid()) @db.Uuid
  environmentId        String      @db.Uuid
  environment          Environment @relation(fields:[environmentId], references:[id], onDelete:Cascade)
  status               ScanStatus  @default(PENDING)
  startedAt            DateTime    @default(now())
  completedAt          DateTime?
  totalAssets          Int         @default(0)
  scannedAssets        Int         @default(0)
  vulnerabilitiesFound Int         @default(0)
  criticalCount        Int         @default(0)
  highCount            Int         @default(0)
  mediumCount          Int         @default(0)
  lowCount             Int         @default(0)
  riskScore            Float?
  isMock               Boolean     @default(false)  // True for dev mode generated scans
  assetScans           AssetScan[]
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  @@index([environmentId])
  @@index([isMock])
}

model AssetScan {
  id              String       @id @default(uuid()) @db.Uuid
  scanId          String       @db.Uuid
  scan            SecurityScan @relation(fields:[scanId], references:[id], onDelete:Cascade)
  assetId         String       @db.Uuid
  asset           Asset        @relation(fields:[assetId], references:[id], onDelete:Cascade)
  vulnerabilities AssetVulnerability[]
  scannedAt       DateTime     @default(now())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([scanId, assetId])
  @@index([scanId])
  @@index([assetId])
}

model Vulnerability {
  id               String       @id @default(uuid()) @db.Uuid
  cveId            String       @unique
  description      String       @db.Text
  cvssScore        Float?
  cvssVector       String?
  severity         VulnSeverity @default(UNKNOWN)
  publishedDate    DateTime?
  lastModifiedDate DateTime?
  
  // Mock vulnerability fields for dev mode testing
  isMock           Boolean      @default(false)
  mockPrompt       String?      @db.Text
  createdBy        String?      @db.Uuid
  
  assetVulnerabilities AssetVulnerability[]
  vulnerabilityWorkflows VulnerabilityWorkflow[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([cveId])
  @@index([severity])
  @@index([isMock])
}

enum VulnStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  FALSE_POSITIVE
  RISK_ACCEPTED
}

model AssetVulnerability {
  id              String        @id @default(uuid()) @db.Uuid
  assetScanId     String        @db.Uuid
  assetScan       AssetScan     @relation(fields:[assetScanId], references:[id], onDelete:Cascade)
  vulnerabilityId String        @db.Uuid
  vulnerability   Vulnerability @relation(fields:[vulnerabilityId], references:[id], onDelete:Cascade)
  cpeName         String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([assetScanId, vulnerabilityId])
  @@index([assetScanId])
  @@index([vulnerabilityId])
}

// VulnerabilityWorkflow tracks remediation state across scans
// Status persists even if CVE is not found in subsequent scans
model VulnerabilityWorkflow {
  id              String        @id @default(uuid()) @db.Uuid
  environmentId   String        @db.Uuid
  environment     Environment   @relation(fields:[environmentId], references:[id], onDelete:Cascade)
  assetId         String        @db.Uuid
  asset           Asset         @relation(fields:[assetId], references:[id], onDelete:Cascade)
  vulnerabilityId String        @db.Uuid
  vulnerability   Vulnerability @relation(fields:[vulnerabilityId], references:[id], onDelete:Cascade)
  cpeName         String
  
  // Remediation state
  status          VulnStatus    @default(OPEN)
  assigneeId      String?       @db.Uuid
  assignee        UserAccount?  @relation("AssignedVulnerabilities", fields:[assigneeId], references:[id])
  notes           String?       @db.Text
  dueDate         DateTime?
  resolvedAt      DateTime?
  resolvedBy      String?       @db.Uuid
  resolver        UserAccount?  @relation("ResolvedVulnerabilities", fields:[resolvedBy], references:[id])
  
  // Tracking
  firstSeenAt     DateTime      @default(now())
  lastSeenAt      DateTime      @default(now())
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@unique([environmentId, assetId, vulnerabilityId, cpeName])
  @@index([environmentId, status])
  @@index([assetId])
  @@index([assigneeId])
  @@index([status])
}